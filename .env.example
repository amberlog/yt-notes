# Optional. Copy to .env to override defaults. All variables are optional.

# HTTP port the local server listens on.
PORT=3000

# Override the path to the yt-dlp binary.
# By default, yt-notes auto-downloads it into ./bin/ on `npm install`.
# YT_DLP_PATH=/full/path/to/yt-dlp

# Override the SQLite DB file path.
# Default: ./yt-notes.db (in the project root)
# YT_NOTES_DB=/full/path/to/yt-notes.db
